#!/bin/sh

MYIP="$(curl -s https://ip.me)"

if curl -s https://api.protonvpn.ch/vpn/servers \
    | grep -q "\"ExitIP\":\"$MYIP\""
then
    echo "OK! ProtonVPN is tunneling this connection"
else
    echo "WARNING! ProtonVPN is not tunneling this connection"
fi

