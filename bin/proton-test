#!/bin/bash
# Proton VPN IP checker using ipinfo.io free Lite API (no token needed for basic lookups).
# Checks if IP belongs to Proton ASNs (209103, 199218, etc.) or org.

IP="$1"
if [ $# -ne 1 ]; then
  IP=$(curl -s https://ip.me)
fi
echo $IP
# Fetch IP details (free tier works without token)
curl -s "https://ipinfo.io/$IP"
